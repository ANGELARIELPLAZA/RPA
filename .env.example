# =========================
# MongoDB (docker-compose)
# =========================
# IMPORTANTE: cambia estos valores antes de levantar en produccion.
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_me_strong_password

MONGO_APP_DB=rpa_tracking
MONGO_APP_USERNAME=rpa_app
MONGO_APP_PASSWORD=change_me_strong_password

# mongo-express (solo profile dev)
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=change_me_strong_password

# =========================
# API security (opcional)
# =========================
# Si defines estos API_KEY, los servicios requeriran `Authorization: Bearer <key>` o `x-api-key: <key>`.
TRACKING_API_KEY=change_me_tracking_key
# Si necesitas exponer /metrics sin auth (no recomendado), pon true.
TRACKING_METRICS_PUBLIC=false

