PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Si defines API_KEY, las rutas (excepto /health) lo requeriran.
API_KEY=change_me_rpa_key
# Si quieres que /screenshots siga siendo publico aun con API_KEY, deja true.
SCREENSHOTS_PUBLIC=false

# CORS: lista separada por comas (ej: https://miapp.com,http://localhost:3000). Vacío = sin CORS.
CORS_ORIGINS=
# Rate limiting (por IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Required: per-agency credentials (when payload includes `agencia` or `agency`).
# User + password per agency (JSON; keys normalized to lowercase):
# CREDENTIALS_BY_AGENCIA={"primavera":{"usuario":"user1","password":"pass1"},"morelos_sur":{"usuario":"user2","password":"pass2"}}
CREDENTIALS_BY_AGENCIA=

HEADLESS=true
RECORD_VIDEO=false

CETELEM_URL=https://cck.creditoclick.com.mx/users-web/auth/kia/login?w=true
PING_TIMEOUT_MS=5000
STATUS_TIMEOUT_MS=4000

SCREENSHOTS_DIR=./screenshots
BASE_URL=http://localhost:3000

MONITOR_ENABLED=true
MONITOR_REFRESH_MS=1000

TRACKING_ENABLED=true
TRACKING_SERVICE_URL=http://rpa-tracking-service:3100
TRACKING_TIMEOUT_MS=3000
# Debe coincidir con rpa-tracking-service API_KEY (si lo usas).
TRACKING_API_KEY=change_me_tracking_key
