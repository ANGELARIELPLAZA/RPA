        ],
        "url": {
          "raw": "http://{{host}}:{{port}}/status/{{task_id}}",
          "protocol": "http",
          "host": ["{{host}}"],
          "port": "{{port}}",
          "path": ["status", "{{task_id}}"]
        }
      }
    },
    {
      "name": "Status - Debug (include_payload)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-api-key", "value": "{{api_key}}", "type": "text" }
        ],
        "url": {
          "raw": "http://{{host}}:{{port}}/status/{{task_id}}?formato=debug&include_payload=1",
          "protocol": "http",
          "host": ["{{host}}"],
          "port": "{{port}}",
          "path": ["status", "{{task_id}}"],
          "query": [
            { "key": "formato", "value": "debug" },
            { "key": "include_payload", "value": "1" }
          ]
        }
      }
    },
