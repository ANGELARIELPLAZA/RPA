PORT=3100
NODE_ENV=production
MONGO_URI=mongodb://rpa_app:change_me@mongo:27017/rpa_tracking?authSource=admin
SERVICE_NAME=rpa-tracking-service
REQUEST_TIMEOUT_MS=3000

# Si defines API_KEY, las rutas (excepto /health y /) lo requeriran.
API_KEY=change_me_tracking_key
# Si necesitas /metrics publico (no recomendado), pon true.
METRICS_PUBLIC=false
# CORS: lista separada por comas (ej: https://miapp.com,http://localhost:3000). Vacío = sin CORS.
CORS_ORIGINS=
# Rate limiting (por IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
